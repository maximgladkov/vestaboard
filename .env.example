VESTABOARD_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
TZ=Europe/Madrid

# Optional: Redis URL used to cache Claude summaries and the last-sent
# grid hash across runs. REQUIRED on render.com cron jobs, which run in
# ephemeral containers with no persistent disk. Without it the script
# falls back to a local .cache.json file (fine for local dev only).
# Examples:
#   REDIS_URL=redis://red-xxxx:6379                 # Render Key-Value internal URL
#   REDIS_URL=rediss://default:TOKEN@host:6379      # Upstash (TLS)
# REDIS_URL=

# Optional: inject Google OAuth material via env vars instead of files.
# If set, these take precedence over credentials.json / tokens/<name>.json.
#
# GOOGLE_CREDENTIALS_JSON='{"installed":{"client_id":"...","client_secret":"...",...}}'
# GOOGLE_TOKEN_PERSONAL='{"token":"...","refresh_token":"...","client_id":"...","client_secret":"...","scopes":["https://www.googleapis.com/auth/calendar.readonly"]}'
# GOOGLE_TOKEN_WORK='{"token":"...","refresh_token":"...",...}'
