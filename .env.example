VESTABOARD_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
TZ=Europe/Madrid

# Optional: inject Google OAuth material via env vars instead of files.
# If set, these take precedence over credentials.json / tokens/<name>.json.
#
# GOOGLE_CREDENTIALS_JSON='{"installed":{"client_id":"...","client_secret":"...",...}}'
# GOOGLE_TOKEN_PERSONAL='{"token":"...","refresh_token":"...","client_id":"...","client_secret":"...","scopes":["https://www.googleapis.com/auth/calendar.readonly"]}'
# GOOGLE_TOKEN_WORK='{"token":"...","refresh_token":"...",...}'
